{
  "name": "@acro/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node src/index.ts",
    "check": "tsc --noEmit",
    "test": "node --test src/*.test.ts",
    "e2e": "node scripts/e2e.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --external:node-pty --external:playwright-core --outfile=dist/runtime.cjs --log-level=warning && esbuild src/daemon/daemon.ts --bundle --platform=node --format=cjs --external:node-pty --outfile=dist/daemon.cjs --log-level=warning"
  },
  "dependencies": {
    "@acro/protocol": "workspace:*",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/headless": "^5.5.0",
    "node-pty": "^1.1.0",
    "playwright-core": "^1.61.1",
    "ws": "^8.18.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.3",
    "esbuild": "^0.28.1"
  }
}
